{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the ECOMIG Portal.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The unique ID of the user." },
        "username": { "type": "string", "description": "The username of the user." },
        "role": { "type": "string", "enum": ["admin", "editor", "viewer"], "description": "The role of the user." },
        "unit": { "type": "string", "description": "The unit of the user (e.g., FHQ, MHQ)." },
        "full_name": { "type": "string", "description": "The full name of the user." },
        "created_at": { "type": "string", "format": "date-time", "description": "The date and time the user was created." }
      },
      "required": ["id", "username", "role", "full_name"]
    },
    "News": {
      "title": "News",
      "description": "A news article.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The unique ID of the news article." },
        "title": { "type": "string", "description": "The title of the news article." },
        "content": { "type": "string", "description": "The content of the news article." },
        "summary": { "type": "string", "description": "A summary of the news article." },
        "image_url": { "type": "string", "description": "The URL of the news article's image." },
        "category": { "type": "string", "description": "The category of the news article." },
        "author": { "type": "string", "description": "The author of the news article." },
        "created_at": { "type": "string", "format": "date-time", "description": "The date and time the news article was created." },
        "updated_at": { "type": "string", "format": "date-time", "description": "The date and time the news article was updated." }
      },
      "required": ["id", "title", "content", "author", "created_at"]
    },
    "Event": {
      "title": "Event",
      "description": "An event.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The unique ID of the event." },
        "title": { "type": "string", "description": "The title of the event." },
        "description": { "type": "string", "description": "The description of the event." },
        "event_date": { "type": "string", "format": "date", "description": "The date of the event." },
        "location": { "type": "string", "description": "The location of the event." },
        "event_type": { "type": "string", "description": "The type of the event." },
        "image_url": { "type": "string", "description": "The URL of the event's image." },
        "created_by": { "type": "string", "description": "The user who created the event." },
        "created_at": { "type": "string", "format": "date-time", "description": "The date and time the event was created." }
      },
      "required": ["id", "title", "description", "event_date", "created_by", "created_at"]
    },
    "GalleryImage": {
      "title": "GalleryImage",
      "description": "An image in the gallery.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The unique ID of the image." },
        "title": { "type": "string", "description": "The title of the image." },
        "description": { "type": "string", "description": "The description of the image." },
        "names": { "type": "string", "description": "The names or labels of people in the image." },
        "image_url": { "type": "string", "description": "The URL of the image." },
        "category": { "type": "string", "description": "The category of the image." },
        "uploaded_by": { "type": "string", "description": "The user who uploaded the image." },
        "created_at": { "type": "string", "format": "date-time", "description": "The date and time the image was uploaded." }
      },
      "required": ["id", "title", "image_url", "uploaded_by", "created_at"]
    },
    "Leader": {
      "title": "Leader",
      "description": "A leader of ECOMIG.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The unique ID of the leader." },
        "name": { "type": "string", "description": "The name of the leader." },
        "title": { "type": "string", "description": "The title of the leader." },
        "position": { "type": "string", "description": "The position of the leader." },
        "unit": { "type": "string", "description": "The unit of the leader." },
        "image_url": { "type": "string", "description": "The URL of the leader's image." },
        "bio": { "type": "string", "description": "The bio of the leader." },
        "order": { "type": "integer", "description": "The order of the leader." }
      },
      "required": ["id", "name", "title", "position", "order"]
    },
    "Department": {
      "title": "Department",
      "description": "A department of ECOMIG.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The unique ID of the department." },
        "name": { "type": "string", "description": "The name of the department." },
        "code": { "type": "string", "description": "The code of the department." },
        "description": { "type": "string", "description": "The description of the department." }
      },
      "required": ["id", "name", "code"]
    },
    "Message": {
      "title": "Message",
      "description": "A contact message.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The unique ID of the message." },
        "name": { "type": "string", "description": "The name of the sender." },
        "email": { "type": "string", "format": "email", "description": "The email of the sender." },
        "subject": { "type": "string", "description": "The subject of the message." },
        "message": { "type": "string", "description": "The message content." },
        "status": { "type": "string", "enum": ["unread", "read"], "description": "The status of the message." },
        "created_at": { "type": "string", "format": "date-time", "description": "The date and time the message was sent." }
      },
      "required": ["id", "name", "email", "subject", "message", "status", "created_at"]
    },
    "MissionDocument": {
      "title": "MissionDocument",
      "description": "A mission document.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The unique ID of the document." },
        "title": { "type": "string", "description": "The title of the document." },
        "category": { "type": "string", "enum": ["SOP", "Manual", "Directive", "Report"], "description": "The category of the document." },
        "file_url": { "type": "string", "description": "The URL of the document file." },
        "uploaded_by": { "type": "string", "description": "The user who uploaded the document." },
        "created_at": { "type": "string", "format": "date-time", "description": "The date and time the document was uploaded." }
      },
      "required": ["id", "title", "category", "uploaded_by", "created_at"]
    },
    "ChatLog": {
      "title": "ChatLog",
      "description": "A log of a chat interaction.",
      "type": "object",
      "properties": {
        "user_id": { "type": "string", "description": "The ID of the user." },
        "user_name": { "type": "string", "description": "The name of the user." },
        "user_unit": { "type": "string", "description": "The unit of the user." },
        "question": { "type": "string", "description": "The user's question." },
        "answer": { "type": "string", "description": "The AI's answer." },
        "created_at": { "type": "string", "format": "date-time", "description": "The date and time of the interaction." }
      },
      "required": ["user_id", "user_name", "user_unit", "question", "answer", "created_at"]
    },
    "InternalMail": {
      "title": "InternalMail",
      "description": "An internal message between users or departments.",
      "type": "object",
      "properties": {
        "sender_id": { "type": "string", "description": "The ID of the sender." },
        "sender_name": { "type": "string", "description": "The name of the sender." },
        "sender_unit": { "type": "string", "description": "The unit of the sender." },
        "receiver_id": { "type": "string", "description": "The ID of the receiver (optional)." },
        "receiver_unit": { "type": "string", "description": "The unit of the receiver (optional)." },
        "subject": { "type": "string", "description": "The subject of the message." },
        "body": { "type": "string", "description": "The content of the message." },
        "is_read": { "type": "boolean", "description": "Whether the message has been read." },
        "attachments": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "url": { "type": "string" },
              "type": { "type": "string" },
              "size": { "type": "number" }
            }
          },
          "description": "List of file attachments."
        },
        "created_at": { "type": "string", "format": "date-time", "description": "The date and time the message was sent." }
      },
      "required": ["sender_id", "sender_name", "sender_unit", "subject", "body", "is_read", "created_at"]
    },
    "ChronicleOfCommand": {
      "title": "ChronicleOfCommand",
      "description": "A record of a commander's tenure.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The unique ID of the record." },
        "name": { "type": "string", "description": "The name of the commander." },
        "unit": { "type": "string", "enum": ["MHQ", "FHQ", "DFC", "J1/4", "J2", "J3/5", "J6", "J7/9", "PM", "PIO", "PA DFC", "CC", "SENBAT", "NIGCOY", "GHANCOY", "SENFPU", "SENPC"], "description": "The unit commanded." },
        "years": { "type": "string", "description": "The years of command (e.g., 2017 - 2018)." },
        "image_url": { "type": "string", "description": "The URL of the commander's image." },
        "created_at": { "type": "string", "format": "date-time", "description": "The date and time the record was created." }
      },
      "required": ["id", "name", "unit", "years", "created_at"]
    },
    "FootballClub": {
      "title": "FootballClub",
      "description": "A football club or team in the ECOMIG competition.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "logo_url": { "type": "string" },
        "played": { "type": "integer" },
        "points": { "type": "integer" },
        "unit": { "type": "string" }
      },
      "required": ["id", "name", "played", "points"]
    },
    "FootballMatch": {
      "title": "FootballMatch",
      "description": "A football match record or upcoming fixture.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "teamA": { "type": "string" },
        "teamB": { "type": "string" },
        "scoreA": { "type": "integer" },
        "scoreB": { "type": "integer" },
        "time": { "type": "string" },
        "status": { "type": "string", "enum": ["live", "upcoming", "finished"] },
        "date": { "type": "string" },
        "stadium": { "type": "string" }
      },
      "required": ["id", "teamA", "teamB", "status", "date"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "The user's profile."
    },
    "/news/{newsId}": {
      "schema": "News",
      "description": "A news article."
    },
    "/events/{eventId}": {
      "schema": "Event",
      "description": "An event."
    },
    "/images/{imageId}": {
      "schema": "GalleryImage",
      "description": "A gallery image."
    },
    "/leaders/{leaderId}": {
      "schema": "Leader",
      "description": "A leader."
    },
    "/departments/{deptId}": {
      "schema": "Department",
      "description": "A department."
    },
    "/messages/{messageId}": {
      "schema": "Message",
      "description": "A contact message."
    },
    "/documents/{docId}": {
      "schema": "MissionDocument",
      "description": "A mission document."
    },
    "/chat_logs/{logId}": {
      "schema": "ChatLog",
      "description": "A chat log."
    },
    "/internal_mail/{mailId}": {
      "schema": "InternalMail",
      "description": "An internal message."
    },
    "/chronicle_of_command/{recordId}": {
      "schema": "ChronicleOfCommand",
      "description": "A record of a commander's tenure."
    },
    "/football_clubs/{clubId}": {
      "schema": "FootballClub",
      "description": "A football club."
    },
    "/football_matches/{matchId}": {
      "schema": "FootballMatch",
      "description": "A football match."
    }
  }
}
